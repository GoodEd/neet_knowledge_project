# OpenAI / OpenRouter Configuration
# Get your key from: https://openrouter.ai/keys or https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Base URL (default is OpenAI, change for OpenRouter/LocalAI)
# For OpenRouter: https://openrouter.ai/api/v1
# For LocalAI/Ollama: http://localhost:11434/v1
# Used by scripts/multi_model_review.py for multi-model code review requests.
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Model name (used for LLM and multimodal transcription)
OPENAI_MODEL_NAME=google/gemini-2.0-flash-001

# Optional: Warm RAG singleton once per Streamlit process at app launch
# Set to 0 to disable startup warm-up
RAG_WARMUP_ON_LAUNCH=1

# YouTube API Configuration (Optional - for robust metadata)
# Get your key from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Telegram Bot Configuration
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
